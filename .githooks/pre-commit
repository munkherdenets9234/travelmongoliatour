#!/usr/bin/env bash
# Security vulnerability check — runs on every commit.
# Checks: (1) secret/credential scanning, (2) dependency vulnerability audit,
# (3) static analysis (SAST) on staged changes.
#
# Bypass (not recommended): git commit --no-verify

set -uo pipefail

RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; NC='\033[0m'
FAIL=0

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "Running pre-commit security checks..."

# ---------- 1. Secret / credential scanning ----------
echo "-> Scanning staged changes for secrets..."
if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks protect --staged --no-banner --redact; then
    echo -e "${RED}x gitleaks found potential secrets in staged changes.${NC}"
    FAIL=1
  fi
else
  echo -e "${YELLOW}  gitleaks not installed; using fallback pattern scan (less thorough).${NC}"
  echo -e "${YELLOW}  Install for full coverage: https://github.com/gitleaks/gitleaks#installing${NC}"
  PATTERN='AKIA[0-9A-Z]{16}|-----BEGIN (RSA|DSA|EC|OPENSSH|PGP) PRIVATE KEY-----|xox[baprs]-[0-9A-Za-z-]{10,}|ghp_[0-9A-Za-z]{36}|gh[oprsu]_[0-9A-Za-z]{36}|AIza[0-9A-Za-z_-]{35}|sk-[A-Za-z0-9]{20,}|eyJhbGciOi[0-9A-Za-z_-]{10,}\.[0-9A-Za-z_-]{10,}\.[0-9A-Za-z_-]{10,}'
  MATCHES=$(git diff --cached -U0 -- . | grep -E -n "$PATTERN" 2>/dev/null || true)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}x Possible secret detected in staged changes:${NC}"
    echo "$MATCHES"
    FAIL=1
  fi
fi

# ---------- 2. Dependency vulnerability audit ----------
if echo "$STAGED_FILES" | grep -qE '(^|/)(package\.json|package-lock\.json)$'; then
  echo "-> Node dependency files changed, running npm audit..."
  if command -v npm >/dev/null 2>&1; then
    if ! npm audit --audit-level=high; then
      echo -e "${RED}x npm audit found high/critical vulnerabilities.${NC}"
      FAIL=1
    fi
  else
    echo -e "${YELLOW}  npm not found; skipping dependency audit.${NC}"
  fi
fi

if echo "$STAGED_FILES" | grep -qE '(^|/)go\.(mod|sum)$'; then
  echo "-> Go module files changed, checking for known vulnerabilities..."
  if command -v govulncheck >/dev/null 2>&1; then
    if ! govulncheck ./...; then
      echo -e "${RED}x govulncheck found known vulnerabilities.${NC}"
      FAIL=1
    fi
  else
    echo -e "${YELLOW}  govulncheck not installed; skipping. Install: go install golang.org/x/vuln/cmd/govulncheck@latest${NC}"
  fi
fi

# ---------- 3. Static analysis (SAST) ----------
CODE_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|jsx|ts|tsx|go|py)$' || true)
if [ -n "$CODE_FILES" ]; then
  echo "-> Running static analysis on changed code files..."
  if command -v semgrep >/dev/null 2>&1; then
    if ! semgrep --config p/ci --error --quiet $CODE_FILES; then
      echo -e "${RED}x semgrep found potential vulnerabilities.${NC}"
      FAIL=1
    fi
  else
    echo -e "${YELLOW}  semgrep not installed; skipping SAST. Install: pip install semgrep${NC}"
  fi
fi

if [ "$FAIL" -ne 0 ]; then
  echo -e "${RED}Commit blocked by security check(s) above.${NC}"
  echo -e "${YELLOW}To bypass in an emergency: git commit --no-verify (not recommended).${NC}"
  exit 1
fi

echo -e "${GREEN}Security checks passed.${NC}"
exit 0
