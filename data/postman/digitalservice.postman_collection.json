              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{superadmin_token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/platform/tenants/{{tenant_id}}/rotate-key",
              "host": ["{{base_url}}"],
              "path": ["platform", "tenants", "{{tenant_id}}", "rotate-key"]
            }
          }
        },
        {
          "name": "Create Tenant Subscription",
          "request": {
            "description": "Starts a subscription for the tenant. `plan` must be one of `free`, `basic`, `pro`, `enterprise` (defaults to `free` if omitted). A tenant can only have one subscription record — this returns 409 if one already exists. No live payment provider is wired in yet; this only tracks plan/status state.",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{superadmin_token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/platform/tenants/{{tenant_id}}/subscription",
              "host": ["{{base_url}}"],
              "path": ["platform", "tenants", "{{tenant_id}}", "subscription"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan\": \"pro\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get Tenant Subscription",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{superadmin_token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/platform/tenants/{{tenant_id}}/subscription",
              "host": ["{{base_url}}"],
              "path": ["platform", "tenants", "{{tenant_id}}", "subscription"]
            }
          }
        },
        {
          "name": "Update Tenant Subscription Plan",
          "request": {
            "description": "Changes the tenant's plan and starts a fresh 30-day billing period. `plan` must be one of `free`, `basic`, `pro`, `enterprise` — any other value returns `400 invalid plan`.",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{superadmin_token}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/v1/platform/tenants/{{tenant_id}}/subscription/plan",
              "host": ["{{base_url}}"],
              "path": ["platform", "tenants", "{{tenant_id}}", "subscription", "plan"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan\": \"enterprise\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Cancel Tenant Subscription",
          "request": {
            "description": "Marks the subscription canceled (sets `canceled_at`). Plan and period fields are left intact.",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{superadmin_token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/platform/tenants/{{tenant_id}}/subscription/cancel",
              "host": ["{{base_url}}"],
              "path": ["platform", "tenants", "{{tenant_id}}", "subscription", "cancel"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth (Tenant Users)",
      "description": "Tenant-scoped login profiles — a tenant can have several (e.g. one admin, several staff). Login is public but still requires X-API-Key to identify which tenant to authenticate against; it returns a Bearer token to copy into {{admin_token}}. The [Admin] requests below let an existing admin add or manage more login profiles for their own tenant. `role` on Create is validated server-side to `admin` or `staff` only — this stops a tenant admin from assigning themselves (or another profile) a `superadmin` role to mint a platform-level token.",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-API-Key", "value": "{{tenant_api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{tenant_admin_email}}\",\n  \"password\": \"{{tenant_admin_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "[Admin] Create Tenant User",
          "request": {
            "description": "`role` must be `admin` or `staff` (defaults to `staff` if omitted). Any other value — including `superadmin` — is rejected with `400 invalid role`; this closes off a privilege-escalation path where a tenant admin could otherwise mint a login profile that logs in with a platform-level token.",
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-API-Key", "value": "{{tenant_api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/users",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bataar Ganbold\",\n  \"email\": \"bataar@nomadtrails.example.com\",\n  \"role\": \"staff\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [
            {
              "name": "Invalid role rejected",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-API-Key", "value": "{{tenant_api_key}}" }],
                "url": {
                  "raw": "{{base_url}}/api/v1/admin/users",
                  "host": ["{{base_url}}"],
                  "path": ["admin", "users"]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Bataar Ganbold\",\n  \"email\": \"bataar@nomadtrails.example.com\",\n  \"role\": \"superadmin\"\n}",
                  "options": { "raw": { "language": "json" } }
                }
              },
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"invalid role\"\n}"
            }
          ]
        },
        {
          "name": "[Admin] List Tenant Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{tenant_api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/users?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "[Admin] Update Tenant User Status",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "X-API-Key", "value": "{{tenant_api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/users/{{tenant_user_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["admin", "users", "{{tenant_user_id}}", "status"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"suspended\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Destinations",
      "item": [
        {
          "name": "List Destinations",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{tenant_api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/destinations?category=cultural&region=gobi&season=summer&page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["destinations"],
              "query": [
                { "key": "category", "value": "cultural" },
                { "key": "region", "value": "gobi" },
