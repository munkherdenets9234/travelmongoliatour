{
  "info": {
    "name": "E&S Travel — DigitalService API",
    "description": "Multi-tenant Go/Gin + MongoDB travel API. Every route except /platform/* is tenant-scoped and requires an X-API-Key header identifying the tenant ({{tenant_api_key}}). Admin routes additionally require a Bearer token with the \"admin\" role, scoped to that same tenant ({{admin_token}}) — obtained via the Auth folder's Login request. The Platform folder manages tenants themselves and requires a Bearer token with the \"superadmin\" role ({{superadmin_token}}) instead of an API key, obtained via the Platform folder's own Login request — see that folder for details on how the first platform user gets bootstrapped and how tenants and their API keys get created.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }]
  },
